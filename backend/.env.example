# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:5173

# MongoDB (Atlas free tier works fine) — if omitted, submissions are
# logged to the console instead of persisted, and the API still responds
# with success so the contact form never breaks for the visitor.
MONGODB_URI=

# Where contact form submissions should be delivered
CONTACT_RECEIVER_EMAIL=bhardwajvidant39@gmail.com

# SMTP credentials (optional — if omitted, submissions are stored/logged
# but not emailed; the API still responds with success)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
